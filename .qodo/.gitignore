# Qodo temporary files and caches
*.qodo-cache
*.qodo-temp
qodo-session-*
.qodo-workspace/
.qodo-analysis/

# Qodo logs
qodo.log
qodo-*.log

# Qodo generated files (temporary)
.qodo-generated/
qodo-backup-*/

# IDE and editor files that might be created during Qodo sessions
.vscode/settings.json.qodo-backup
.idea/workspace.xml.qodo-backup